<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>MaxGrade | Mis Clases</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light" data-selected-section="<%= selectedSection %>">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <a class="navbar-brand d-flex align-items-center me-2" href="/">
                    <img src="/public/img/maxgradeplacapng.png" alt="MaxGrade" class="navbar-logo">
                </a>
                <button class="btn btn-light border-0 text-dark" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <a href="#" class="nav-action text-dark small d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#joinModal">
                        <i class="fa-solid fa-link"></i>
                        <span>Unirse a una clase</span>
                    </a>
                    <a href="#" class="nav-action text-dark small d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createModal">
                        <i class="fa-solid fa-plus"></i>
                        <span>Crea una clase</span>
                    </a>
                    <a href="#" class="nav-action text-dark small d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#supportModal">
                        <i class="fa-solid fa-headset"></i>
                        <span>Soporte</span>
                    </a>
                    <div class="dropdown">
                        <button class="btn avatar-circle" data-bs-toggle="dropdown">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="d-flex align-items-center gap-2 text-decoration-none">
                    <!-- sidebar brand intentionally left blank to keep space for menu -->
                    <div style="height:8px;"></div>
            </div>
        </div>
        <ul class="sidebar-menu">
            <li>Realiza click en el boton deseado para ir a donde desees:</li>
            <li><a href="#" data-section="classes" class="sidebar-link <%= selectedSection === 'classes' ? 'active' : '' %>"><i class="fa-solid fa-graduation-cap me-3"></i>Mis clases</a></li>
            <li><a href="#" data-section="calendar" class="sidebar-link <%= selectedSection === 'calendar' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-list me-3"></i>Tareas</a></li>
            <li><a href="#" data-section="submissions" class="sidebar-link <%= selectedSection === 'submissions' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-check me-3"></i>Entregadas</a></li>
            <li><a href="/mis-reportes" class="sidebar-link"><i class="fa-solid fa-headset me-3"></i>Mis reportes</a></li>
            <li><a href="/terminos" class="sidebar-link"><i class="fa-solid fa-file-contract me-3"></i>Términos y condiciones</a></li>
            <li><a href="/privacidad" class="sidebar-link"><i class="fa-solid fa-user-shield me-3"></i>Aviso de privacidad</a></li>
        </ul>
        <div class="sidebar-footer">
            <div class="mt-3">
                <a href="/logout" class="btn btn-outline-danger btn-sm w-100">
                    <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesión
                </a>
            </div>
        </div>
    </aside>

    <main class="main-content container py-4">
        <div class="content-section <%= selectedSection === 'classes' ? 'active' : '' %>" id="classes-section">
            <% if (!clases || clases.length === 0) { %>
            <div class="empty-state-card">
                <div class="empty-illustration" aria-hidden="true">
                    <span class="angle angle-top"></span>
                    <span class="angle angle-left"></span>
                    <span class="angle angle-bottom"></span>
                    <span class="angle-center"></span>
                </div>
                <div class="empty-copy text-center">
                    <h2>Ups...</h2>
                    <p>Parece que por aquí no hay nada, realiza click en los siguientes botones para crear o unirte a una clase para seguir.</p>
                </div>
                <div class="empty-actions">
                    <a href="#" class="action-btn" data-bs-toggle="modal" data-bs-target="#joinModal">
                        <i class="fa-solid fa-arrow-down-left"></i>
                        UNIRSE A UNA CLASE
                    </a>
                    <a href="#" class="action-btn" data-bs-toggle="modal" data-bs-target="#createModal">
                        <i class="fa-solid fa-arrow-down-right"></i>
                        CREA UNA CLASE
                    </a>
                </div>
            </div>
            <% } %>
            <% if (clases && clases.length > 0) { %>
            <div class="row" id="classContainer">
                <% clases.forEach(clase => { %>
                    <div class="col-md-4 col-lg-3 mb-4">
                        <div class="card h-100 shadow-sm border-0 class-card">
                            <div class="card-header text-white p-3 position-relative class-banner" data-bg="<%= clase.portada_url || '' %>">
                                <% if (clase.portada_url) { %>
                                    <div style="background: rgba(0,0,0,0.5); position: absolute; top: 0; left: 0; right: 0; bottom: 0;"></div>
                                <% } %>
                                <div class="position-relative" style="z-index: 1;">
                                    <h5 class="card-title mb-0"><%= clase.nombre_clase %></h5>
                                    <p class="small opacity-75"><%= clase.seccion %></p>
                                </div>
                                <% if (clase.isProfesor) { %>
                                    <label for="bannerInput<%= clase.id %>" 
                                           class="btn btn-sm btn-light rounded-circle position-absolute top-0 end-0 m-2"
                                           style="z-index: 2; cursor: pointer;">
                                        <i class="fa-solid fa-image"></i>
                                        <input type="file" 
                                               id="bannerInput<%= clase.id %>" 
                                               hidden 
                                               accept="image/*"
                                               onchange="uploadBanner('<%= clase.id %>', event)">
                                    </label>
                                <% } %>
                            </div>
                            <div class="card-body d-flex flex-column justify-content-between">
                                <p class="card-text small text-muted">Profesor: <%= clase.profesor ? (clase.profesor.nombre + ' ' + (clase.profesor.apellido || '')) : 'No asignado' %></p>
                                <div class="text-end">
                                    <a href="/clase/<%= clase.id %>" class="btn btn-outline-primary btn-sm rounded-pill">Entrar</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
            <% } %>
        </div>

        <div class="content-section <%= selectedSection === 'calendar' ? 'active' : '' %>" id="calendar-section">
            <div class="row">
                <div class="col-12">
                    <h3 class="mb-4"><i class="fa-solid fa-calendar me-2"></i>Calendario de Tareas Pendientes</h3>
                    <div id="calendarContainer" class="calendar-container">
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-section <%= selectedSection === 'submissions' ? 'active' : '' %>" id="submissions-section">
            <div class="row">
                <div class="col-12">
                    <h3 class="mb-4"><i class="fa-solid fa-check-circle me-2"></i>Mis Entregas</h3>
                    <div id="submissionsContainer">
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('modals/classModals') %>
    <%- include('modals/supportModal') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/dashboard.js"></script>
    <script src="/public/js/support.js"></script>
</body>
</html>