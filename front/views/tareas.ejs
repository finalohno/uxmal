<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Trabajo en clase | <%= clase.nombre_clase %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/dashboard"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold"><%= clase.nombre_clase %></span>
            <div class="mx-auto">
                <ul class="nav nav-underline">
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>">Novedades</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">Trabajo en clase</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/personas">Personas</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/rendimiento">Rendimiento de clase</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-normal">Trabajo en clase</h2>
            <% if (isProfesor) { %>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createUnitModal" data-clase-id="<%= clase.id %>">
                        <i class="fa-solid fa-folder-plus me-2"></i> Crear unidad
                    </button>
                    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createAssignmentModal" data-clase-id="<%= clase.id %>">
                        <i class="fa-solid fa-plus me-2"></i> Crear tarea
                    </button>
                </div>
            <% } %>
        </div>

        <div id="assignmentsList">
            <% if (Object.keys(tareasAgrupadas).length === 0 && tareassSinUnidad.length === 0) { %>
                <div class="text-center py-5 mt-5">
                    <img src="/public/img/tasks.png" style="width: 200px; opacity: 0.5;">
                    <p class="text-muted mt-3">Aún no se han asignado tareas aquí.</p>
                </div>
            <% } else { %>

                <% Object.keys(tareasAgrupadas).forEach(unitId => { %>
                    <% const grupo = tareasAgrupadas[unitId]; %>
                    <% if (grupo.tareas.length > 0) { %>
                        <div class="mb-4">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fa-solid fa-folder text-primary me-2" style="font-size: 1.5rem;"></i>
                                <div>
                                    <h5 class="mb-0 fw-bold">Unidad <%= grupo.unidad.numero_unidad %>: <%= grupo.unidad.nombre %></h5>
                                    <% if (grupo.unidad.descripcion) { %>
                                        <small class="text-muted"><%= grupo.unidad.descripcion %></small>
                                    <% } %>
                                </div>
                                <% if (isProfesor) { %>
                                    <button class="btn btn-sm btn-outline-danger ms-auto" title="Eliminar unidad" onclick="deleteUnit('<%= grupo.unidad.id %>')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                <% } %>
                            </div>
                            <div class="ps-4">
                                <% grupo.tareas.forEach(tarea => { %>
                                    <div class="card border-0 shadow-sm mb-3 task-item">
                                        <div class="card-body d-flex align-items-center">
                                            <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="fa-solid fa-clipboard-list"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-0 fw-bold"><%= tarea.titulo %></h6>
                                                <small class="text-muted">Publicado el <%= new Date(tarea.fecha_creacion).toLocaleDateString() %></small>
                                            </div>
                                            <div class="text-end">
                                                <a href="/tarea/<%= tarea.id %>" class="btn btn-light btn-sm rounded-pill">Ver tarea</a>
                                                <% if (isProfesor) { %>
                                                    <button class="btn btn-outline-warning btn-sm rounded-pill ms-2" data-unit-id="<%= tarea.unidad_id || '' %>" onclick="editAssignment('<%= tarea.id %>', '<%= clase.id %>', this.dataset.unitId)">Mover</button>
                                                    <button class="btn btn-outline-danger btn-sm rounded-pill ms-2" onclick="deleteAssignment('<%= tarea.id %>')">Eliminar</button>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>
                <% }) %>

                <!-- Mostrar tareas sin unidad al final -->
                <% if (tareassSinUnidad.length > 0) { %>
                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fa-solid fa-inbox text-secondary me-2" style="font-size: 1.5rem;"></i>
                            <h5 class="mb-0 fw-bold">Sin asignar a una unidad</h5>
                        </div>
                        <div class="ps-4">
                            <% tareassSinUnidad.forEach(tarea => { %>
                                <div class="card border-0 shadow-sm mb-3 task-item">
                                    <div class="card-body d-flex align-items-center">
                                        <div class="bg-secondary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fa-solid fa-clipboard-list"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 fw-bold"><%= tarea.titulo %></h6>
                                            <small class="text-muted">Publicado el <%= new Date(tarea.fecha_creacion).toLocaleDateString() %></small>
                                        </div>
                                        <div class="text-end">
                                            <a href="/tarea/<%= tarea.id %>" class="btn btn-light btn-sm rounded-pill">Ver tarea</a>
                                            <% if (isProfesor) { %>
                                                <button class="btn btn-outline-warning btn-sm rounded-pill ms-2" data-unit-id="<%= tarea.unidad_id || '' %>" onclick="editAssignment('<%= tarea.id %>', '<%= clase.id %>', this.dataset.unitId)">Asignar a unidad</button>
                                                <button class="btn btn-outline-danger btn-sm rounded-pill ms-2" onclick="deleteAssignment('<%= tarea.id %>')">Eliminar</button>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% } %>
            <% } %>
        </div>
    </main>

    <%- include('modals/assigmentModal') %>

    <div class="modal fade" id="editAssignmentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title">Asignar a unidad</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Seleccionar unidad</label>
                        <select id="editTaskUnit" class="form-control">
                            <option value="">-- Sin unidad --</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary px-4" onclick="saveTaskUnit()">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/tareas.js"></script>
</body>
</html>