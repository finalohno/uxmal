<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel de Soporte | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <a class="navbar-brand d-flex align-items-center me-2" href="/">
                    <img src="/public/img/maxgradeplacapng.png" alt="MaxGrade" class="navbar-logo">
                </a>
                <button class="btn btn-light border-0 text-dark" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <a href="/support" class="nav-action text-dark small d-flex align-items-center gap-2">
                        <i class="fa-solid fa-headset"></i>
                        <span>Panel de Soporte</span>
                    </a>
                    <div class="dropdown">
                        <button class="btn avatar-circle" data-bs-toggle="dropdown">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div style="height:8px;"></div>
        </div>
        <ul class="sidebar-menu">
            <li>Panel técnico</li>
            <li><a href="/support" class="sidebar-link active"><i class="fa-solid fa-headset me-3"></i>Reportes</a></li>
        </ul>
        <div class="sidebar-footer">
            <div class="mt-3">
                <a href="/logout" class="btn btn-outline-danger btn-sm w-100">
                    <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesión
                </a>
            </div>
        </div>
    </aside>

    <main class="main-content container py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start align-items-lg-center mb-4 gap-3">
                    <div>
                        <h2 class="mb-1">Panel de Soporte</h2>
                        <p class="text-muted mb-0">Aquí puedes ver todos los reportes y dar seguimiento.</p>
                    </div>
                </div>

                <div id="supportList">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <div class="mt-3 text-muted">Cargando reportes...</div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/support.js"></script>
        <!-- Detail modal -->
        <div class="modal fade" id="reportDetailModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Detalle del reporte</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <div id="reportDetailBody">
                            <p><strong>Tipo:</strong> <span id="detailTipo"></span></p>
                            <p><strong>Creado por:</strong> <span id="detailAutor"></span></p>
                            <p><strong>Fecha:</strong> <span id="detailFecha"></span></p>
                            <p><strong>Descripción:</strong></p>
                            <p id="detailDescripcion"></p>
                            <p id="detailEvidencia"></p>
                            <div class="mb-3">
                                <label class="form-label">Estado</label>
                                <select id="detailEstado" class="form-select">
                                    <option value="abierto">Abierto</option>
                                    <option value="en_progreso">En progreso</option>
                                    <option value="cerrado">Cerrado</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button id="saveReportChanges" type="button" class="btn btn-primary">Guardar cambios</button>
                    </div>
                </div>
            </div>
        </div>
    <script>
        async function loadAllReports() {
            try {
                const res = await fetch('/api/support', { credentials: 'include' });
                if (!res.ok) throw new Error('No se pudo cargar');
                const data = await res.json();
                const container = document.getElementById('supportList');
                if (!data || data.length === 0) {
                    container.innerHTML = '<div class="text-muted">No hay reportes.</div>';
                    return;
                }
                container.innerHTML = data.map(r => `
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <strong>${new Date(r.fecha_creacion).toLocaleString()}</strong>
                                    <div class="text-muted">${r.tipo_problema || 'Reporte de soporte'}</div>
                                </div>
                                <div class="text-end">
                                    <div><span class="badge bg-light text-dark">${r.estado === 'abierto' ? 'Abierto' : (r.estado === 'en_progreso' ? 'En progreso' : 'Cerrado')}</span></div>
                                    <div class="small text-muted mt-2">Asignado: ${r.asignado ? (r.asignado.nombre + ' ' + (r.asignado.apellido||'')) : '—'}</div>
                                </div>
                            </div>
                            <p class="mt-3 mb-3">${r.descripcion || ''}</p>
                            <div class="row gx-2 gy-2 align-items-center">
                                <div class="col-auto">
                                    <select class="form-select form-select-sm status-select" data-id="${r.id}">
                                        <option value="abierto" ${r.estado === 'abierto' ? 'selected' : ''}>Abierto</option>
                                        <option value="en_progreso" ${r.estado === 'en_progreso' ? 'selected' : ''}>En progreso</option>
                                        <option value="cerrado" ${r.estado === 'cerrado' ? 'selected' : ''}>Cerrado</option>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" onclick="openAssignDialog(${r.id})">Asignar</button>
                                </div>
                                <div class="col-auto">
                                    <a href="/support/${r.id}" class="btn btn-sm btn-outline-primary">Ver</a>
                                </div>
                            </div>
                        </div>
                    </div>
                `).join('');

                
                        document.querySelectorAll('.status-select').forEach(sel => {
                    sel.addEventListener('change', async (e) => {
                        const id = e.target.dataset.id;
                        const newStatus = e.target.value;
                        await fetch(`/api/support/${id}`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            credentials: 'include',
                            body: JSON.stringify({ estado: newStatus })
                        });
                        
                    });
                });

                      
                        document.querySelectorAll('.view-btn').forEach(btn => {
                            btn.addEventListener('click', async (e) => {
                                const id = e.target.dataset.id;
                                try {
                                    const res = await fetch(`/api/support/${id}`, { credentials: 'include' });
                                    if (!res.ok) throw new Error('No se pudo cargar el detalle');
                                    const r = await res.json();
                                    document.getElementById('detailTipo').innerText = r.tipo_problema || '';
                                    document.getElementById('detailAutor').innerText = r.reporter ? (r.reporter.nombre + ' ' + (r.reporter.apellido||'')) : (r.usuario_id || '');
                                    document.getElementById('detailFecha').innerText = new Date(r.fecha_creacion).toLocaleString();
                                    document.getElementById('detailDescripcion').innerText = r.descripcion || '';
                                    const ev = document.getElementById('detailEvidencia');
                                    if (r.url_evidencia) ev.innerHTML = `<a href="${r.url_evidencia}" target="_blank" class="link-primary">Ver evidencia</a>`;
                                    else ev.innerHTML = '';
                                    document.getElementById('detailEstado').value = r.estado || 'abierto';
                                    // store current id
                                    document.getElementById('saveReportChanges').dataset.id = id;
                                    const modal = new bootstrap.Modal(document.getElementById('reportDetailModal'));
                                    modal.show();
                                } catch (err) {
                                    showError('Error', err.message);
                                }
                            });
                        });

                     
                        document.getElementById('saveReportChanges').addEventListener('click', async (e) => {
                            const id = e.target.dataset.id;
                            const newStatus = document.getElementById('detailEstado').value;
                            try {
                                const res = await fetch(`/api/support/${id}`, {
                                    method: 'PATCH',
                                    headers: { 'Content-Type': 'application/json' },
                                    credentials: 'include',
                                    body: JSON.stringify({ estado: newStatus })
                                });
                                if (!res.ok) throw new Error('No se pudo actualizar');
                                
                                const modalEl = document.getElementById('reportDetailModal');
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                if (modal) modal.hide();
                                await loadAllReports();
                            } catch (err) {
                                showError('Error', err.message);
                            }
                        });


            } catch (err) {
                document.getElementById('supportList').innerHTML = `<div class="alert alert-danger">${err.message}</div>`;
            }
        }

        loadAllReports();
    </script>
</body>
</html>