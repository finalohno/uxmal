<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= tarea.titulo %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-light bg-white border-bottom sticky-top">
        <div class="container">
            <a class="btn btn-light me-2" href="/clase/<%= tarea.clase_id %>/tareas"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold">Tarea</span>
        </div>
    </nav>

    <main class="container mt-5" style="max-width: 1000px;">
        <div class="row">
            <div class="col-md-8">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-circle p-3 me-3">
                        <i class="fa-solid fa-clipboard-list fa-2x"></i>
                    </div>
                    <div>
                        <h1 class="h3 mb-0"><%= tarea.titulo %></h1>
                        <p class="text-muted small mb-0">
                            <%= tarea.clases.profesor.nombre %> <%= tarea.clases.profesor.apellido %> • <%= new Date(tarea.fecha_creacion).toLocaleDateString() %>
                        </p>
                        <div class="d-flex justify-content-between border-bottom pb-2 mt-2">
                            <span class="fw-bold small"><%= tarea.puntos_maximos %> puntos</span>
                            <small>
                                Fecha de entrega: <%= new Date(tarea.fecha_entrega).toLocaleDateString('es-ES') %> a las <%= new Date(tarea.fecha_entrega).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %>
                            </small>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <p><%= tarea.descripcion || tarea.instrucciones || '' %></p>
                </div>

                <div id="rubricasDetalleContainer" class="mt-4"></div>

                <% if (tarea.archivo_guia_url) { %>
                    <div class="mt-4">
                        <h6 class="fw-bold">Materiales de apoyo</h6>
                        <a href="<%= tarea.archivo_guia_url %>" target="_blank" class="card d-inline-block text-decoration-none border shadow-sm p-3" style="max-width: 300px;">
                            <div class="d-flex align-items-center">
                                <i class="fa-solid fa-file-pdf fa-2x text-danger me-3"></i>
                                <span class="text-dark text-truncate">Ver material adjunto</span>
                            </div>
                        </a>
                    </div>
                <% } %>
            </div>

            <div class="col-md-4">
                <% if (rol === 'profesor') { %>
                    <div class="card shadow-sm border-0 p-3 mb-3">
                        <h5 class="fw-bold mb-3">Resumen de entregas</h5>
                        <% const totalAlumnos = alumnosConEstado ? alumnosConEstado.length : 0; %>
                        <% const entregadosCount = alumnosConEstado ? alumnosConEstado.filter(a => a.entrega).length : 0; %>
                        <% const faltantesCount = totalAlumnos - entregadosCount; %>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-success">Entregados: <%= entregadosCount %></span>
                            <span class="badge bg-secondary">Faltantes: <%= faltantesCount %></span>
                            <span class="badge bg-info text-dark">Total: <%= totalAlumnos %></span>
                        </div>

                        <% if (faltantesCount > 0) { %>
                            <details class="mt-2">
                                <summary class="small text-muted">Ver quién no entregó</summary>
                                <ul class="list-unstyled mt-2 mb-0">
                                    <% alumnosConEstado.filter(a => !a.entrega).forEach(a => { %>
                                        <li class="small">• <%= a.nombre %> <%= a.apellido %></li>
                                    <% }) %>
                                </ul>
                            </details>
                        <% } else { %>
                            <p class="small text-muted mb-0">Todos los alumnos entregaron.</p>
                        <% } %>
                    </div>

                    <div class="card shadow-sm border-0 p-3">
                        <h5 class="fw-bold mb-3">Entregas de estudiantes</h5>
                        <a href="/tarea/<%= tarea.id %>/revision" class="btn btn-primary w-100 mb-3">Ver y calificar entregas</a>
                        <% if (entregas && entregas.length > 0) { %>
                            <% entregas.forEach(entrega => { %>
                                <div class="d-flex align-items-center justify-content-between mb-2 p-2 border rounded">
                                    <div>
                                        <strong><%= entrega.estudiante.nombre %> <%= entrega.estudiante.apellido %></strong>
                                        <br>
                                        <small class="text-muted">Entregado: <%= new Date(entrega.fecha_envio || entrega.created_at).toLocaleDateString() %></small>
                                    </div>
                                    <% if (entrega.archivo_entrega_url) { %>
                                        <a href="<%= entrega.archivo_entrega_url %>" target="_blank" class="btn btn-sm btn-outline-primary">Ver</a>
                                    <% } else { %>
                                        <span class="text-muted small">Sin archivo</span>
                                    <% } %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">No hay entregas aún.</p>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="card shadow-sm border-0 p-3 rounded-4 bg-white">
                        <h5 class="fw-bold mb-3">Tu trabajo</h5>
                        
                        <% if (entrega) { %>
                            <div class="alert alert-success small">Tarea entregada</div>
                            <% if (entrega.calificacion !== null && entrega.calificacion !== undefined) { %>
                                <div class="alert alert-warning small mb-3">
                                    Esta entrega ya está calificada. Al anularla se eliminará el registro de entrega y la calificación actual.
                                </div>
                            <% } %>
                            <% if (entrega.archivo_entrega_url) { %>
                                <a href="<%= entrega.archivo_entrega_url %>" target="_blank" class="btn btn-outline-secondary w-100 mb-2">Ver mi entrega</a>
                                <% 
                                    let filenameFromUrl = 'archivo';
                                    try {
                                        if (entrega && entrega.archivo_entrega_url) {
                                            const parts = entrega.archivo_entrega_url.split('/');
                                            filenameFromUrl = decodeURIComponent(parts[parts.length - 1] || 'archivo');
                                        }
                                    } catch(e) { filenameFromUrl = 'archivo'; }
                                %>
                                <div class="small text-muted mt-2 text-center">Archivo: <a href="<%= entrega.archivo_entrega_url %>" target="_blank"><%= entrega.nombre_archivo || filenameFromUrl %></a></div>
                            <% } %>
                            <button type="button" class="btn btn-danger w-100 mt-3" onclick="cancelSubmission('<%= entrega.id %>')">
                                Anular entrega
                            </button>
                            <% if (entrega.calificacion !== null && entrega.calificacion !== undefined) { %>
                                <div class="mt-3 p-3 bg-light rounded">
                                    <strong>Calificación: <%= entrega.calificacion %> / <%= tarea.puntos_maximos %> puntos</strong>
                                    <% if (entrega.comentario_profesor) { %>
                                        <div class="mt-2 p-2 bg-white border-start border-primary rounded">
                                            <small class="text-muted d-block">Comentario del profesor:</small>
                                            <p class="mb-0 mt-1"><%= entrega.comentario_profesor %></p>
                                        </div>
                                    <% } %>
                                </div>
                                <div id="studentRubricGradesContainer" class="mt-3"></div>
                            <% } %>
                            <% if (entrega.comentario_alumno) { %>
                                <div class="mt-3 p-2 bg-light border-start border-info rounded">
                                    <small class="text-muted d-block">Tu comentario:</small>
                                    <p class="mb-0 mt-1"><%= entrega.comentario_alumno %></p>
                                </div>
                            <% } %>
                        <% } else { %>
                            <form id="submissionForm" onsubmit="return false;" autocomplete="off">
                                <div class="mb-3">
                                    <label class="btn btn-outline-primary w-100 py-3 border-dashed">
                                        <i class="fa-solid fa-plus me-2"></i> Añadir
                                        <input type="file" id="submissionFile" name="archivo_entrega" hidden accept="*/*">
                                    </label>
                                    <div id="fileNameDisplay" class="small text-muted mt-2 text-center"></div>
                                </div>
                                <div class="mb-3">
                                    <label for="comentarioAlumno" class="form-label">Comentario privado (opcional)</label>
                                    <textarea class="form-control" id="comentarioAlumno" rows="3" placeholder="Añade un comentario privado para tu profesor..."></textarea>
                                    <div class="d-flex gap-2 mt-2">
                                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="startVoiceDictation('comentarioAlumno', this)">Dictar comentario</button>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-primary w-100 py-2" onclick="submitTask('<%= tarea.id %>')">Entregar tarea</button>
                            </form>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/entrega.js"></script>
    <script src="/public/js/rubrics.js"></script>
    <script>
        function initDetalleTareaPage() {
            const tareaId = '<%= tarea.id %>';
            if (tareaId && typeof loadRubricsForTaskDetail === 'function') {
                loadRubricsForTaskDetail(tareaId);
            }

            const entregaId = '<%= entrega?.id %>';
            if (entregaId && typeof loadStudentRubricGrades === 'function') {
                loadStudentRubricGrades(entregaId);
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initDetalleTareaPage);
        } else {
            initDetalleTareaPage();
        }
    </script>
</body>
</html>