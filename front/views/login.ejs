<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MaxGrade | Iniciar Sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/auth.css">
</head>
<body>
    <div class="auth-page">
        <section class="auth-side">
            <div class="circle"></div>
            <div class="content">
                <h1>Bienvenido de Nuevo</h1>
                <p>Inicia sesión para ver tus clases y continuar con tus tareas en MaxGrade.</p>
            </div>
        </section>

        <section class="auth-main">
            <div class="auth-card">
                <div class="auth-brand">
                    <img src="/public/img/maxgrade1.jpg" alt="Logo MaxGrade">
                    <h2>MaxGrade</h2>
                </div>

                <h3>Iniciar Sesión</h3>
                <p class="subtitle">Ingresa tus datos para acceder a tu área educativa.</p>

                <form id="loginForm">
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" placeholder="nombre@ejemplo.com" required>
                        <label for="email">Correo electrónico</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="password" placeholder="Contraseña" maxlength="16" required>
                        <label for="password">Contraseña</label>
                    </div>
                    <div id="errorMessage" class="alert alert-danger d-none" role="alert"></div>
                    <button class="btn btn-primary w-100" type="submit" id="loginBtn">Iniciar Sesión</button>
                    <div class="link-row">
                        ¿Aún no tienes una cuenta? <a href="/registro">CREA UNA</a>
                    </div>
                    <div class="link-row">
                         <a href="/">Volver al menu</a>
                    </div>
                </form>
            </div>
        </section>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/login.js"></script>
</body>
</html>