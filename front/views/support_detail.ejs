<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Detalle del Reporte | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <a class="navbar-brand d-flex align-items-center me-2" href="/">
                    <img src="/public/img/maxgradeplacapng.png" alt="MaxGrade" class="navbar-logo">
                </a>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <div class="dropdown">
                        <button class="btn avatar-circle" data-bs-toggle="dropdown">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="main-content container py-4">
        <div class="row">
            <div class="col-12">
                <div class="mb-4">
                    <a href="/support" class="btn btn-link">← Volver a reportes</a>
                    <h2>Reporte: <small class="text-muted">#<%= report.id %></small></h2>
                </div>

                <div class="card">
                    <div class="card-body">
                        <p><strong>Tipo:</strong> <%= report.tipo_problema %></p>
                        <p><strong>Creado por:</strong> <%= reporter ? (reporter.nombre + ' ' + (reporter.apellido||'')) : report.usuario_id %></p>
                        <p><strong>Asignado a:</strong> <%= report.asignado ? (report.asignado.nombre + ' ' + (report.asignado.apellido||'')) : '—' %></p>
                        <p><strong>Fecha:</strong> <%= new Date(report.fecha_creacion).toLocaleString() %></p>
                        <p><strong>Descripción:</strong></p>
                        <p><%= report.descripcion %></p>

                        <% if (report.url_evidencia) { %>
                            <div class="mb-3">
                                <strong>Evidencia:</strong>
                                <div class="mt-2">
                                    <% if (report.url_evidencia.match(/\.(jpg|jpeg|png|gif|webp)$/i)) { %>
                                        <img src="<%= report.url_evidencia %>" alt="Evidencia" class="img-fluid border rounded">
                                    <% } else { %>
                                        <a href="<%= report.url_evidencia %>" target="_blank" class="btn btn-sm btn-outline-primary">Ver evidencia</a>
                                    <% } %>
                                </div>
                            </div>
                        <% } %>

                        <div class="mb-3">
                            <label class="form-label">Estado</label>
                            <select id="pageEstado" class="form-select w-50">
                                <option value="abierto" <%= report.estado === 'abierto' ? 'selected' : '' %>>Abierto</option>
                                <option value="cerrado" <%= report.estado === 'cerrado' ? 'selected' : '' %>>Cerrado</option>
                            </select>
                        </div>

                        <div>
                            <button id="savePageChanges" class="btn btn-primary">Guardar cambios</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function setButtonLoading(btn, loading, label) {
            if (!btn) return;
            if (loading) {
                if (!btn.dataset.origHtml) btn.dataset.origHtml = btn.innerHTML;
                btn.disabled = true;
                const spinner = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>';
                btn.innerHTML = `${spinner}${label || 'Procesando...'}`;
            } else {
                if (btn.dataset.origHtml) {
                    btn.innerHTML = btn.dataset.origHtml;
                    delete btn.dataset.origHtml;
                }
                btn.disabled = false;
            }
        }

        const saveButton = document.getElementById('savePageChanges');
        saveButton.addEventListener('click', async () => {
            const id = <%= report.id %>;
            const estado = document.getElementById('pageEstado').value;
            try {
                setButtonLoading(saveButton, true, 'Guardando...');
                const res = await fetch(`/api/support/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ estado })
                });
                if (!res.ok) {
                    const j = await res.json().catch(() => ({}));
                    throw new Error(j.error || 'No se pudo guardar');
                }
                alert('Cambios guardados');
                window.location.href = '/support';
            } catch (err) {
                alert('Error: ' + (err.message || err));
            } finally {
                setButtonLoading(saveButton, false);
            }
        });
    </script>
</body>
</html>
