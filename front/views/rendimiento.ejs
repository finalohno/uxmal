<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rendimiento | <%= clase.nombre_clase %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/clase/<%= clase.id %>"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold"><%= clase.nombre_clase %></span>
            
            <div class="mx-auto">
                <ul class="nav nav-underline">
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>">Novedades</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/tareas">Trabajo en clase</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/personas">Personas</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">Rendimiento de clase</a></li>
                </ul>
            </div>

            <% if (isProfesor) { %>
                <button class="btn btn-outline-danger btn-sm" onclick="eliminarClase('<%= clase.id %>')">
                    <i class="fa-solid fa-trash"></i> Eliminar clase
                </button>
            <% } %>
        </div>
    </nav>

    <main class="container mt-4" style="max-width: 900px;">
        <div class="p-5 mb-4 rounded-3 text-white shadow-sm position-relative overflow-hidden" 
             style="background-image: url('<%= clase.portada_url || '' %>');
                    background-color: #1a73e8; 
                    background-size: cover; 
                    background-position: center;
                    min-height: 200px;">
            <% if (clase.portada_url) { %>
                <div style="background: rgba(0,0,0,0.5); position: absolute; top: 0; left: 0; right: 0; bottom: 0;"></div>
            <% } %>
            <div class="container-fluid py-5 position-relative" style="z-index: 1;">
                <h1 class="display-5 fw-bold"><%= clase.nombre_clase %></h1>
                <p class="fs-4"><%= clase.seccion %></p>
            </div>
        </div>

        <% if (isProfesor && classPerformance) { %>
        <div class="mb-5">
            <h4 class="fw-bold mb-4">
                <i class="fa-solid fa-chart-line"></i> Rendimiento General de la Clase
            </h4>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <p class="text-muted small mb-1">Promedio</p>
                                    <h3 class="mb-0 fw-bold"><%= classPerformance.promedioCalificacion %></h3>
                                </div>
                                <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="fa-solid fa-star fa-lg"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-3">Distribución de Entregas</h6>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-success">A Tiempo</span>
                                        <%= classPerformance.entregadasAtiempo %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-success" 
                                         style="width: <%= classPerformance.totalEntregas > 0 ? (classPerformance.entregadasAtiempo / classPerformance.totalEntregas * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-warning">Fuera de Plazo</span>
                                        <%= classPerformance.entregadasTarde %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-warning" 
                                         style="width: <%= classPerformance.totalEntregas > 0 ? (classPerformance.entregadasTarde / classPerformance.totalEntregas * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-danger">No Entregadas</span>
                                        <%= classPerformance.noEntregadas %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-danger" 
                                         style="width: <%= classPerformance.noEntregadas > 0 ? (classPerformance.noEntregadas / (classPerformance.totalEstudiantes * classPerformance.totalTareas) * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-3">Estado de Calificación</h6>
                            
                            <div class="list-group list-group-flush">
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Tareas Calificadas</span>
                                    <span class="badge bg-success rounded-pill"><%= classPerformance.totalEntregas - classPerformance.tareasSinCalificar %></span>
                                </div>
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Tareas Pendientes de Calificar</span>
                                    <span class="badge bg-warning rounded-pill"><%= classPerformance.tareasSinCalificar %></span>
                                </div>
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Total de Entregas Recibidas</span>
                                    <span class="badge bg-primary rounded-pill"><%= classPerformance.totalEntregas %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <% if (isProfesor && studentsList && studentsList.length > 0) { %>
        <div class="mb-5">
            <h4 class="fw-bold mb-4">
                <i class="fa-solid fa-user-chart"></i> Rendimiento Individual
            </h4>

            <div class="mb-4">
                <label for="studentSelector" class="form-label fw-bold">Seleccionar Alumno</label>
                <select class="form-select" id="studentSelector" onchange="actualizarRendimientoIndividual()">
                    <option value="">-- Selecciona un alumno --</option>
                    <% studentsList.forEach(student => { %>
                        <option value="<%= student.id %>"><%= student.nombre %> <%= student.apellido %></option>
                    <% }); %>
                </select>
            </div>

            <div id="studentPerformanceSection" style="display: none;">
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <p class="text-muted small mb-1">Promedio</p>
                                        <h3 class="mb-0 fw-bold" id="studentAverage">0.00</h3>
                                    </div>
                                    <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-star fa-lg"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <p class="text-muted small mb-1">Entregadas</p>
                                        <h3 class="mb-0 fw-bold" id="studentDelivered">0</h3>
                                    </div>
                                    <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-check fa-lg"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <p class="text-muted small mb-1">% Entrega</p>
                                        <h3 class="mb-0 fw-bold" id="studentDeliveryPercent">0%</h3>
                                    </div>
                                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-percent fa-lg"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <p class="text-muted small mb-1">Calificadas</p>
                                        <h3 class="mb-0 fw-bold" id="studentGraded">0</h3>
                                    </div>
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-clipboard-check fa-lg"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title fw-bold mb-3">Distribución de Entregas</h6>
                                
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="small">
                                            <span class="badge bg-success">A Tiempo</span>
                                            <span id="studentOnTime">0</span>
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-success" id="studentOnTimeBar" style="width: 0%"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="small">
                                            <span class="badge bg-warning">Fuera de Plazo</span>
                                            <span id="studentLate">0</span>
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-warning" id="studentLateBar" style="width: 0%"></div>
                                    </div>
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="small">
                                            <span class="badge bg-danger">No Entregadas</span>
                                            <span id="studentNotDelivered">0</span>
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-danger" id="studentNotDeliveredBar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title fw-bold mb-3">Resumen</h6>
                                
                                <div class="list-group list-group-flush">
                                    <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                        <span class="small">Tareas Entregadas</span>
                                        <span class="badge bg-info rounded-pill" id="studentTotalDelivered">0</span>
                                    </div>
                                    <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                        <span class="small">Tareas No Entregadas</span>
                                        <span class="badge bg-danger rounded-pill" id="studentTotalNotDelivered">0</span>
                                    </div>
                                    <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                        <span class="small">Tareas Calificadas</span>
                                        <span class="badge bg-success rounded-pill" id="studentTotalGraded">0</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <% if (!isProfesor) { %>
            <div class="alert alert-info" role="alert">
                <i class="fa-solid fa-circle-info"></i> El rendimiento de clase solo está disponible para profesores.
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script type="application/json" id="studentPerformanceData"><%- studentPerformanceMapJson %></script>
    <script>
        const studentPerformanceMap = JSON.parse(document.getElementById('studentPerformanceData').textContent) || {};
        
        console.log('studentPerformanceMap loaded:', studentPerformanceMap);

        function actualizarRendimientoIndividual() {
            const selector = document.getElementById('studentSelector');
            const studentId = selector.value;
            
            console.log('Selected student ID:', studentId);
            console.log('Available students:', Object.keys(studentPerformanceMap));

            if (!studentId) {
                document.getElementById('studentPerformanceSection').style.display = 'none';
                return;
            }

            const performance = studentPerformanceMap[studentId];
            console.log('Performance data:', performance);
            
            if (!performance) {
                showError('Datos no encontrados', 'No se encontraron datos para este alumno');
                return;
            }

            document.getElementById('studentAverage').textContent = performance.promedioCalificacion;
            document.getElementById('studentDelivered').textContent = performance.tareasEntregadas;
            document.getElementById('studentDeliveryPercent').textContent = performance.porcentajeEntrega + '%';
            document.getElementById('studentGraded').textContent = performance.tareasCalificadas;

            document.getElementById('studentOnTime').textContent = performance.entregadasAtiempo;
            document.getElementById('studentLate').textContent = performance.entregadasTarde;
            document.getElementById('studentNotDelivered').textContent = performance.noEntregadas;

            const totalTareas = performance.entregadasAtiempo + performance.entregadasTarde + performance.noEntregadas;
            const onTimePercent = totalTareas > 0 ? (performance.entregadasAtiempo / totalTareas * 100).toFixed(1) : 0;
            const latePercent = totalTareas > 0 ? (performance.entregadasTarde / totalTareas * 100).toFixed(1) : 0;
            const notDeliveredPercent = totalTareas > 0 ? (performance.noEntregadas / totalTareas * 100).toFixed(1) : 0;

            document.getElementById('studentOnTimeBar').style.width = onTimePercent + '%';
            document.getElementById('studentLateBar').style.width = latePercent + '%';
            document.getElementById('studentNotDeliveredBar').style.width = notDeliveredPercent + '%';

            document.getElementById('studentTotalDelivered').textContent = performance.tareasEntregadas;
            document.getElementById('studentTotalNotDelivered').textContent = performance.noEntregadas;
            document.getElementById('studentTotalGraded').textContent = performance.tareasCalificadas;

            document.getElementById('studentPerformanceSection').style.display = 'block';
        }

        async function eliminarClase(claseId) {
            showConfirm(
                '¿Eliminar clase?',
                '¿Estás seguro de que deseas eliminar esta clase? Esta acción no se puede deshacer.',
                'Sí, eliminar',
                'Cancelar'
            ).then(async (result) => {
                if (!result.isConfirmed) return;

                showLoading('Eliminando clase', 'Por favor espere...');

                try {
                    const response = await fetch(`/api/classes/${claseId}`, {
                        method: 'DELETE',
                        credentials: 'include'
                    });

                    if (response.ok) {
                        await showSuccess('Clase eliminada', 'La clase ha sido eliminada correctamente');
                        window.location.href = '/dashboard';
                    } else {
                        const error = await response.json().catch(() => ({}));
                        showError('Error al eliminar', error.error || 'No se pudo eliminar la clase');
                    }
                } catch (error) {
                    showError('Error de conexión', 'No se pudo conectar con el servidor');
                }
            });
        }
    </script>
</body>
</html>
