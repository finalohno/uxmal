<div class="modal fade" id="rubricModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title">Crear Rúbrica Estándar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Criterio</label>
                    <input type="text" class="form-control" id="newRubricCriterio" placeholder="ej: Claridad de escritura">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Descripción (opcional)</label>
                    <textarea class="form-control" id="newRubricDescripcion" rows="2" placeholder="Describe qué se evalúa en este criterio..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Puntos máximos</label>
                    <input type="number" class="form-control" id="newRubricPuntos" min="1" max="1000" placeholder="10">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="createNewRubric(this)">Crear</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editRubricModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title">Editar Rúbrica</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editRubricId">
                <div class="mb-3">
                    <label class="form-label fw-bold">Criterio</label>
                    <input type="text" class="form-control" id="editRubricCriterio">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Descripción</label>
                    <textarea class="form-control" id="editRubricDescripcion" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Puntos máximos</label>
                    <input type="number" class="form-control" id="editRubricPuntos" min="1" max="1000">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="saveRubricChanges()">Guardar</button>
            </div>
        </div>
    </div>
</div>
