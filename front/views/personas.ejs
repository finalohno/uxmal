<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Trabajo en clase | <%= clase.nombre_clase %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/dashboard"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold"><%= clase.nombre_clase %></span>
            <div class="mx-auto">
                <ul class="nav nav-underline">
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>">Novedades</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/tareas">Trabajo en clase</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">Personas</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/rendimiento">Rendimiento de clase</a></li>
                </ul>
            </div>
        </div>
    </nav>
 <div class="container mt-5" style="max-width: 800px;">
    <div class="mb-5">
        <div class="d-flex align-items-center border-bottom border-primary border-2 mb-3 pb-2">
            <h2 class="text-primary mb-0 flex-grow-1">Profesores</h2>

        </div>
        <div class="list-group list-group-flush">
            <% if (profesores && profesores.length > 0) { %>
                <% profesores.forEach(p => { %>
                    <div class="list-group-item d-flex align-items-center border-0 px-0 py-3">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                            <%= p.usuarios.nombre.charAt(0) %><%= p.usuarios.apellido.charAt(0) %>
                        </div>
                        <span class="fw-medium">
                            <%= p.usuarios.nombre %> <%= p.usuarios.apellido %>
                        </span>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-muted ps-2">No hay profesores asignados.</p>
            <% } %>
        </div>
    </div>

    <div>
        <div class="d-flex align-items-center border-bottom border-primary border-2 mb-3 pb-2">
            <h2 class="text-primary mb-0 flex-grow-1">Alumnos</h2>
            <span class="text-muted me-3 small"><%= alumnos.length %> alumnos</span>
        </div>
        <div class="list-group list-group-flush">
            <% if (alumnos && alumnos.length > 0) { %>
                <% alumnos.forEach(a => { %>
                    <div class="list-group-item d-flex align-items-center border-0 px-0 py-3">
                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                            <%= a.usuarios.nombre.charAt(0) %><%= a.usuarios.apellido.charAt(0) %>
                        </div>
                        <span class="fw-medium">
                            <%= a.usuarios.nombre %> <%= a.usuarios.apellido %>
                        </span>
                        <div class="ms-auto">
                            <% if (isProfesor) { %>
                                <button class="btn btn-sm btn-outline-danger" onclick="removeStudent('<%= clase.id %>', '<%= a.usuarios.id %>', '<%= a.usuarios.nombre %> <%= a.usuarios.apellido %>')">Dar de baja</button>
                            <% } else { %>
                                <button class="btn btn-link text-muted"><i class="fa-regular fa-envelope"></i></button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-5">
                    <img src="/public/img/no-students.png" alt="Sin alumnos" style="width: 120px; opacity: 0.5;">
                    <p class="text-muted mt-3">Aún no hay alumnos inscritos en esta clase.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>   

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script>
        async function removeStudent(classId, studentId, studentName) {
            showConfirm(
                '¿Dar de baja alumno?',
                `¿Estás seguro de que deseas dar de baja a ${studentName}?`,
                'Sí, dar de baja',
                'Cancelar'
            ).then(async (result) => {
                if (!result.isConfirmed) return;

                showLoading('Dando de baja alumno', 'Por favor espere...');

                try {
                    const response = await fetch(`/api/classes/${classId}/students/${studentId}`, {
                        method: 'DELETE',
                        credentials: 'include'
                    });

                    if (response.ok) {
                        await showSuccess('Alumno dado de baja', `${studentName} ha sido dado de baja correctamente`);
                        location.reload();
                    } else {
                        const errorData = await response.json().catch(() => null);
                        showError('Error al dar de baja', errorData?.error || 'No se pudo dar de baja al alumno');
                    }
                } catch (err) {
                    showError('Error de conexión', 'No se pudo conectar con el servidor');
                }
            });
        }
    </script>
</body>
