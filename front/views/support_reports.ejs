<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis reportes | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/dashboard.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid px-0">
            <div class="navbar-inner d-flex align-items-center position-relative w-100">
                <a class="navbar-brand d-flex align-items-center me-2" href="/">
                    <img src="/public/img/maxgradeplacapng.png" alt="MaxGrade" class="navbar-logo">
                </a>
                <button class="btn btn-light border-0 text-dark" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                <div class="navbar-actions d-flex align-items-center gap-3 ms-auto">
                    <a href="/dashboard" class="nav-action text-dark small d-flex align-items-center gap-2">
                        <i class="fa-solid fa-house"></i>
                        <span>Dashboard</span>
                    </a>
                    <div class="dropdown">
                        <button class="btn avatar-circle" data-bs-toggle="dropdown">
                            <% if (user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" class="avatar-image">
                            <% } else { %>
                                <span class="avatar-fallback"><%= user && user.nombre ? user.nombre.charAt(0).toUpperCase() : '?' %></span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div style="height:8px;"></div>
        </div>
        <ul class="sidebar-menu">
            <li>Realiza click en el boton deseado para ir a donde desees:</li>
            <li><a href="/dashboard" class="sidebar-link"><i class="fa-solid fa-graduation-cap me-3"></i>Mis clases</a></li>
            <li><a href="#" class="sidebar-link active"><i class="fa-solid fa-headset me-3"></i>Mis reportes</a></li>
            <li><a href="/terminos" class="sidebar-link"><i class="fa-solid fa-file-contract me-3"></i>Términos y condiciones</a></li>
            <li><a href="/privacidad" class="sidebar-link"><i class="fa-solid fa-user-shield me-3"></i>Aviso de privacidad</a></li>
        </ul>
        <div class="sidebar-footer">
            <div class="mt-3">
                <a href="/logout" class="btn btn-outline-danger btn-sm w-100">
                    <i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesión
                </a>
            </div>
        </div>
    </aside>

    <main class="main-content container py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start align-items-lg-center mb-4 gap-3">
                    <div>
                        <h2 class="mb-1">Mis reportes de soporte</h2>
                        <p class="text-muted mb-0">Aquí verás el historial de tus solicitudes al equipo de soporte.</p>
                    </div>
                    <a href="/dashboard" class="btn btn-light btn-sm">
                        <i class="fa-solid fa-arrow-left me-1"></i> Volver al dashboard
                    </a>
                </div>
                <div id="reportsContainer">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <div class="mt-3 text-muted">Cargando tus reportes...</div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/dashboard.js"></script>
    <script>
        async function loadReports() {
            try {
                const res = await fetch('/api/support/my', { credentials: 'include' });
                if (!res.ok) throw new Error('No se pudo cargar');
                const data = await res.json();
                const container = document.getElementById('reportsContainer');
                if (!data || data.length === 0) {
                    container.innerHTML = '<div class="text-muted">No tienes reportes de soporte.</div>';
                    return;
                }
                container.innerHTML = data.map(r => `
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <strong>${new Date(r.fecha_creacion).toLocaleString()}</strong>
                                    <div class="text-muted">${r.tipo_problema || 'Reporte de soporte'}</div>
                                </div>
                                <div><span class=\"badge ${r.estado === 'abierto' ? 'bg-info' : (r.estado === 'en_progreso' ? 'bg-warning text-dark' : 'bg-success')}\">${r.estado === 'abierto' ? 'Abierto' : (r.estado === 'en_progreso' ? 'En progreso' : 'Cerrado')}</span></div>
                            </div>
                            <p class="mt-3 mb-1">${r.descripcion || ''}</p>
                            ${r.url_evidencia ? `<p class="mb-0"><a href="${r.url_evidencia}" target="_blank" class="link-primary">Ver evidencia</a></p>` : ''}
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                document.getElementById('reportsContainer').innerHTML = `<div class="alert alert-danger">${err.message}</div>`;
            }
        }

        loadReports();
    </script>
</body>
</html>