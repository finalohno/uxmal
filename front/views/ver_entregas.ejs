<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Entregas: <%= tarea.titulo %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/tarea/<%= tarea.id %>"><i class="fa-solid fa-arrow-left"></i> Volver</a>
            <span class="navbar-brand">Revision de Tarea: <strong><%= tarea.titulo %></strong></span>
        </div>
    </nav>

    <main class="container-fluid mt-4">
        <div class="row">
            <div class="col-md-4 col-lg-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold">Alumnos</div>
                    <div class="list-group list-group-flush">
                        <% alumnos.forEach(alumno => { %>
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" 
                                    onclick='verDetalleEntrega(<%- JSON.stringify(alumno) %>)'>
                                <div>
                                    <p class="mb-0 small fw-bold"><%= alumno.nombre %> <%= alumno.apellido %></p>
                                    <span class="badge <%= alumno.entrega ? 'bg-success' : 'bg-secondary' %>" style="font-size: 0.7rem;">
                                        <%= alumno.entrega ? 'Entregado' : 'Sin entregar' %>
                                    </span>
                                </div>
                                <% if (alumno.entrega && alumno.entrega.calificacion) { %>
                                    <span class="text-primary fw-bold"><%= alumno.entrega.calificacion %>/<%= tarea.puntos_maximos %></span>
                                <% } %>
                            </button>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="col-md-8 col-lg-9">
                <div id="detalleEntrega" data-tarea-id="<%= tarea.id %>" class="card shadow-sm border-0 p-4 text-center">
                    <i class="fa-solid fa-user-graduate fa-4x text-muted mb-3 opacity-25"></i>
                    <p class="text-muted">Selecciona un alumno para revisar su trabajo.</p>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/js/swal-utils.js"></script>
    <script src="/public/js/calificar.js"></script>
    <script src="/public/js/rubrics.js"></script>
    <script>
        function initVerEntregasPage() {
            const tareaId = '<%= tarea.id %>';
            if (tareaId && typeof loadRubricsForGrading === 'function') {
                loadRubricsForGrading(tareaId);
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initVerEntregasPage);
        } else {
            initVerEntregasPage();
        }
    </script>
</body>
</html>